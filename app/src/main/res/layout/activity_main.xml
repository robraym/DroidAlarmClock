<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainScroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oneUiBackground"
    android:clipToPadding="false"
    android:fillViewport="true"
    tools:context="ray.droid.com.droidalarmclock.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="18dp"
        android:paddingTop="30dp"
        android:paddingRight="18dp"
        android:paddingBottom="48dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alarme"
            android:textColor="@color/oneUiText"
            android:textSize="28sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/nextAlarmCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_oneui_card"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingTop="12dp"
            android:paddingRight="16dp"
            android:paddingBottom="12dp">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_oneui_icon_soft"
                android:contentDescription="Próximo alarme"
                android:padding="10dp"
                android:src="@drawable/ic_oneui_alarm"
                android:tint="@color/colorWhite" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginLeft="14dp"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/nextAlarmTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Nenhum alarme agendado"
                    android:textColor="@color/oneUiText"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/nextAlarmSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Toque em Agendar para atualizar"
                    android:textColor="@color/oneUiTextMuted"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_oneui_card"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingTop="14dp"
            android:paddingRight="16dp"
            android:paddingBottom="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_oneui_icon_blue"
                    android:contentDescription="Horário"
                    android:padding="10dp"
                    android:src="@drawable/ic_oneui_clock"
                    android:tint="@color/colorWhite" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Horário"
                        android:textColor="@color/oneUiText"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Escolha o horário do alarme"
                        android:textColor="@color/oneUiTextMuted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="118dp"
                android:layout_marginTop="6dp"
                android:gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/hourColumn"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp">

                    <TextView
                        android:id="@+id/hourPrevious"
                        style="@style/OneUiTimeAdjacent" />

                    <View
                        android:layout_width="96dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="6dp"
                        android:background="@color/oneUiTextMuted" />

                    <TextView
                        android:id="@+id/hourValue"
                        style="@style/OneUiTimeValue" />

                    <View
                        android:layout_width="96dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="6dp"
                        android:background="@color/oneUiTextMuted" />

                    <TextView
                        android:id="@+id/hourNext"
                        style="@style/OneUiTimeAdjacent" />
                </LinearLayout>

                <TextView
                    android:layout_width="32dp"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:text=":"
                    android:textColor="@color/oneUiText"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/minuteColumn"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingLeft="8dp"
                    android:paddingRight="8dp">

                    <TextView
                        android:id="@+id/minutePrevious"
                        style="@style/OneUiTimeAdjacent" />

                    <View
                        android:layout_width="96dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="6dp"
                        android:background="@color/oneUiTextMuted" />

                    <TextView
                        android:id="@+id/minuteValue"
                        style="@style/OneUiTimeValue" />

                    <View
                        android:layout_width="96dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="6dp"
                        android:layout_marginBottom="6dp"
                        android:background="@color/oneUiTextMuted" />

                    <TextView
                        android:id="@+id/minuteNext"
                        style="@style/OneUiTimeAdjacent" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_oneui_card"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingTop="14dp"
            android:paddingRight="16dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_oneui_icon_soft"
                    android:contentDescription="Repetir"
                    android:padding="10dp"
                    android:src="@drawable/ic_oneui_repeat"
                    android:tint="@color/colorWhite" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Repetir"
                        android:textColor="@color/oneUiText"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Marque os dias da semana"
                        android:textColor="@color/oneUiTextMuted"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:columnCount="2">

                <CheckBox
                    android:id="@+id/chkSeg"
                    style="@style/OneUiDayCheck"
                    android:text="Segunda" />

                <CheckBox
                    android:id="@+id/chkTer"
                    style="@style/OneUiDayCheck"
                    android:text="Terça" />

                <CheckBox
                    android:id="@+id/chkQua"
                    style="@style/OneUiDayCheck"
                    android:text="Quarta" />

                <CheckBox
                    android:id="@+id/chkQui"
                    style="@style/OneUiDayCheck"
                    android:text="Quinta" />

                <CheckBox
                    android:id="@+id/chkSex"
                    style="@style/OneUiDayCheck"
                    android:text="Sexta" />

                <CheckBox
                    android:id="@+id/chkSab"
                    style="@style/OneUiDayCheck"
                    android:text="Sábado" />

                <CheckBox
                    android:id="@+id/chkDom"
                    style="@style/OneUiDayCheck"
                    android:text="Domingo" />
            </GridLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnAgendar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:background="@drawable/bg_oneui_button_compact"
            android:text="Agendar"
            android:textAllCaps="false"
            android:textColor="@color/colorWhite"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
