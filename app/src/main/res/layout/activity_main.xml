<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/oneUiBackground"
    android:fillViewport="true"
    tools:context="ray.droid.com.droidalarmclock.MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingLeft="20dp"
        android:paddingTop="28dp"
        android:paddingRight="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Alarme"
            android:textColor="@color/oneUiText"
            android:textSize="34sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:background="@drawable/bg_oneui_card"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="18dp"
            android:paddingRight="18dp"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_oneui_icon_blue"
                    android:contentDescription="Horario"
                    android:padding="11dp"
                    android:src="@drawable/ic_oneui_clock"
                    android:tint="@color/colorWhite" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Horario"
                        android:textColor="@color/oneUiText"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Escolha quando o alarme deve tocar"
                        android:textColor="@color/oneUiTextMuted"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <TimePicker
                android:id="@+id/timePicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:theme="@style/OneUiTimePickerTheme"
                android:timePickerMode="spinner" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_oneui_card"
            android:orientation="vertical"
            android:paddingLeft="18dp"
            android:paddingTop="18dp"
            android:paddingRight="18dp"
            android:paddingBottom="18dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_oneui_icon_soft"
                    android:contentDescription="Repetir"
                    android:padding="11dp"
                    android:src="@drawable/ic_oneui_repeat"
                    android:tint="@color/oneUiBlue" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Repetir"
                        android:textColor="@color/oneUiText"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Marque os dias da semana"
                        android:textColor="@color/oneUiTextMuted"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:columnCount="2">

                <CheckBox
                    android:id="@+id/chkSeg"
                    style="@style/OneUiDayCheck"
                    android:text="Segunda" />

                <CheckBox
                    android:id="@+id/chkTer"
                    style="@style/OneUiDayCheck"
                    android:text="Terca" />

                <CheckBox
                    android:id="@+id/chkQua"
                    style="@style/OneUiDayCheck"
                    android:text="Quarta" />

                <CheckBox
                    android:id="@+id/chkQui"
                    style="@style/OneUiDayCheck"
                    android:text="Quinta" />

                <CheckBox
                    android:id="@+id/chkSex"
                    style="@style/OneUiDayCheck"
                    android:text="Sexta" />

                <CheckBox
                    android:id="@+id/chkSab"
                    style="@style/OneUiDayCheck"
                    android:text="Sabado" />

                <CheckBox
                    android:id="@+id/chkDom"
                    style="@style/OneUiDayCheck"
                    android:text="Domingo" />
            </GridLayout>
        </LinearLayout>

        <Button
            android:id="@+id/btnAgendar"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_oneui_button"
            android:text="Agendar"
            android:textAllCaps="false"
            android:textColor="@color/colorWhite"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>
